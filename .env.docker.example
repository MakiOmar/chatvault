# Copy to .env on your VPS: cp .env.docker.example .env

# --- App ---
NODE_ENV=production
PORT=3001

# --- MySQL (used by app + mysql container) ---
# Docker creates DB + user on first start — no manual CREATE DATABASE needed.
# If password contains # or $, wrap in double quotes, e.g. DB_PASSWORD="p@ss#word$"
DB_HOST=mysql
DB_USER=chatvault
DB_PASSWORD=change-me-strong-db-password
DB_NAME=chatvault
MYSQL_ROOT_PASSWORD=change-me-root-password

# --- Security (generate: openssl rand -base64 48) ---
JWT_SECRET=change-me-long-random-secret-at-least-32-characters

# --- Published port (host → nginx) ---
HTTP_PORT=80
